# OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/video_clips

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth - CHANGE THESE IN PRODUCTION
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage paths
UPLOAD_DIR=./storage/uploads
OUTPUT_DIR=./storage/outputs
TEMP_DIR=./storage/temp

# Processing defaults
DEFAULT_CLIP_COUNT=3
DEFAULT_CLIP_LENGTH=30
MAX_FILE_SIZE_MB=500

# Task settings
TASK_MAX_RETRIES=3
TASK_RETRY_DELAY=60

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100

# Debug mode (set to true for development)
DEBUG=false

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube OAuth (Google API Console)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Instagram OAuth (Facebook Developer Portal)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
